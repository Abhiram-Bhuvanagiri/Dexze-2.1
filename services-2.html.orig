                        </div>

                        <!-- Item 5 (Left) -->
                        <div class="tech-item reveal-item"
                            style="height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; text-align: left; padding: 0 5vw; width: 100%;">
                            <div data-speed="1.2" style="max-width: 900px;">
                                <span
                                    style="color: #00EBD6; font-size: 18px; font-weight: 500; letter-spacing: 2px; margin-bottom: 20px; display: block;">05
                                    /</span>
                                <h2
                                    style="font-family: var(--td-ff-heading), sans-serif; font-size: clamp(36px, 6vw, 90px); font-weight: 700; line-height: 1.1; margin: 0 0 30px 0; letter-spacing: -3px; background: linear-gradient(135deg, #00EBD6 0%, #008F82 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                                    Intelligent<br>Automations</h2>
                                <p
                                    style="color: rgba(255,255,255,0.8); font-size: clamp(18px, 2vw, 24px); line-height: 1.6; font-weight: 400; margin: 0; max-width: 600px;">
                                    Streamline your operations and eliminate repetitive tasks. Our intelligent
                                    automation solutions leverage smart algorithms to optimize efficiency, saving
                                    countless hours of manual work.</p>
