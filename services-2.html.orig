                        </div>

                        <style>
                            .stats-grid-section .row {
                                perspective: 1500px;
                            }

                            /* 3D Fold-Out Reveal */
                            .grid-card-reveal {
                                opacity: 0;
                                transform: rotateX(45deg) translateY(80px) scale(0.9);
                                transform-origin: bottom center;
                                transition: opacity 1s ease, transform 1s cubic-bezier(0.2, 0.9, 0.3, 1.1);
                            }

                            .grid-card-reveal:nth-child(1) {
                                transition-delay: 0.1s;
                            }

                            .grid-card-reveal:nth-child(2) {
                                transition-delay: 0.3s;
                            }

                            .grid-card-reveal:nth-child(3) {
                                transition-delay: 0.5s;
                            }

                            .grid-card-reveal.is-visible {
                                opacity: 1;
                                transform: rotateX(0deg) translateY(0) scale(1);
                            }

                            /* Staggered Inner Text Reveal */
                            .stat-card span,
                            .stat-card h2,
                            .stat-card p {
                                opacity: 0;
                                transform: translateY(20px);
                                transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
                            }

                            .grid-card-reveal.is-visible .stat-card span {
                                transition-delay: 0.4s;
                                opacity: 1;
                                transform: translateY(0);
                            }

                            .grid-card-reveal.is-visible .stat-card h2 {
                                transition-delay: 0.6s;
                                opacity: 1;
                                transform: translateY(0);
                            }

                            .grid-card-reveal.is-visible .stat-card p {
                                transition-delay: 0.8s;
                                opacity: 1;
                                transform: translateY(0);
                            }

                            /* Premium Hover Effect */
                            .stat-card {
                                border: 1px solid transparent;
                                transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
                            }

                            .stat-card:hover {
                                transform: translateY(-15px) scale(1.02) !important;
                                box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03) !important;
                            }

                            .stat-card::after {
                                content: '';
                                position: absolute;
                                bottom: 0;
                                left: 0;
                                width: 100%;
                                height: 0;
                                background: linear-gradient(90deg, #6F2BFF, #00EBD6);
                                transition: height 0.3s ease;
                                border-radius: 0 0 20px 20px;
                                opacity: 0;
                            }

                            .stat-card:hover::after {
                                height: 4px;
                                opacity: 1;
                            }
                        </style>
                        <script>
                            document.addEventListener("DOMContentLoaded", function () {
                                const observer = new IntersectionObserver((entries) => {
                                    entries.forEach(entry => {
                                        if (entry.isIntersecting) {
                                            entry.target.classList.add('is-visible');

                                            // Animate numbers
                                            const counter = entry.target.querySelector('.count-up');
                                            if (counter && !counter.classList.contains('counted')) {
                                                counter.classList.add('counted');
                                                const target = +counter.getAttribute('data-target');
                                                const speed = 40; // The lower the slower
                                                const increment = target / speed;

                                                const updateCount = () => {
                                                    const count = +counter.innerText;
                                                    if (count < target) {
                                                        counter.innerText = Math.ceil(count + increment);
                                                        setTimeout(updateCount, 40);
                                                    } else {
                                                        counter.innerText = target;
                                                    }
                                                };

                                                // Delay counter to match the 3D flip stagger timing
                                                setTimeout(updateCount, 600);
                                            }
                                        }
                                    });
                                }, { threshold: 0.2 });

                                document.querySelectorAll('.grid-card-reveal').forEach(item => {
                                    observer.observe(item);
                                });
                            });
                        </script>
                    </div>
